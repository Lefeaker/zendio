{
  "name": "all-in-ob",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "clean": "rimraf build/dist build/releases",
    "typecheck": "npm run typecheck:app && npm run typecheck:tests",
    "typecheck:app": "tsc --noEmit --project tsconfig.json",
    "typecheck:tests": "tsc --noEmit --project tsconfig.tests.json",
    "typecheck:strict": "tsc --noEmit --project tsconfig.strict.json",
    "lint": "eslint src tests --ext .ts,.tsx,.js",
    "lint:fix": "npm run lint -- --fix",
    "lint:type-any": "node scripts/audit-types.mjs --format summary",
    "lint:hardcoded": "node scripts/lint-hardcoded-values.mjs",
    "lint:options-css": "stylelint \"src/options/**/*.css\"",
    "lint:warnings-report": "node scripts/lint-warnings-report.mjs",
    "lint:warnings-guard": "node scripts/lint-warnings-guard.mjs",
    "audit:deps:report": "npx --yes dependency-cruiser@16.10.4 --config .dependency-cruiser.cjs --output-type err-long src",
    "audit:platform-services:report": "node tools/report-platform-services-allowlist.mjs",
    "audit:design-tokens:report": "node tools/report-design-token-alignment.mjs",
    "audit:design-system-doc:report": "node tools/report-design-system-doc.mjs",
    "audit:interaction-contract:report": "node tools/report-interaction-contract.mjs",
    "audit:options-mainline:report": "node tools/report-options-mainline.mjs",
    "audit:repository-composition:report": "node tools/report-repository-composition.mjs",
    "audit:locales:report": "node tools/report-locale-source-alignment.mjs",
    "audit:imports:report": "node tools/report-deep-imports.mjs",
    "audit:components:report": "node tools/report-component-entry-alignment.mjs",
    "audit:build:report": "node tools/report-build-splitting.mjs",
    "audit:performance:report": "node tools/report-performance-hotspots.mjs",
    "perf:content:baseline": "node tools/collect-content-performance-baseline.mjs",
    "manifest:generate": "node scripts/generate-manifests.mjs",
    "i18n:generate": "node scripts/gen-locales.mjs",
    "i18n:lint": "node scripts/lint-i18n.mjs",
    "i18n:guard": "node scripts/i18n-guard.mjs",
    "layout:report": "node scripts/layout-report.mjs",
    "test:i18n:layout": "npm run layout:report",
    "test:i18n:visual": "playwright test --config=playwright.config.ts",
    "validate:i18n:budgets": "tsx tools/validate-text-budgets.ts",
    "generate:i18n:pseudo": "tsx tools/generate-pseudo-locale.ts",
    "test:i18n": "npm run i18n:lint && npm run validate:i18n:budgets && npm run test:i18n:layout",
    "quality:i18n": "npm run test:i18n && npm run test:i18n:visual",
    "report:layout": "node tools/generate-layout-summary.mjs",
    "report:release-summary": "node tools/generate-release-summary.mjs",
    "format": "prettier --write \"{src,tests,docs}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"{src,tests,docs}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "tailwind:build": "tailwindcss -c tailwind.config.cjs -i src/options/styles/tailwind.input.css -o src/options/styles/tailwind.css --minify",
    "tailwind:watch": "tailwindcss -c tailwind.config.cjs -i src/options/styles/tailwind.input.css -o src/options/styles/tailwind.css --watch",
    "tailwind:build:clipper": "tailwindcss -c tailwind.config.clipper.cjs -i src/styles/clipper/tailwind.input.css -o src/styles/clipper/clipper.tailwind.css --minify",
    "tailwind:build:global": "tailwindcss -c tailwind.config.global.cjs -i src/styles/tailwind.input.global.css -o src/styles/global.tailwind.css --minify",
    "tailwind:watch:global": "tailwindcss -c tailwind.config.global.cjs -i src/styles/tailwind.input.global.css -o src/styles/global.tailwind.css --watch",
    "tailwind:build:video": "tailwindcss -c tailwind.config.video.cjs -i src/styles/clipper/tailwind.input.video.css -o src/styles/clipper/video.tailwind.css --minify",
    "tailwind:watch:video": "tailwindcss -c tailwind.config.video.cjs -i src/styles/clipper/tailwind.input.video.css -o src/styles/clipper/video.tailwind.css --watch",
    "quality": "node scripts/quality-check.mjs",
    "build": "npm run quality && node scripts/build.mjs --mode=prod",
    "build:fast": "node scripts/build.mjs --mode=prod --skip-checks",
    "build:dev": "node scripts/build.mjs --skip-checks",
    "build:firefox": "npm run quality && node scripts/build.mjs --mode=prod --firefox",
    "build:firefox:fast": "node scripts/build.mjs --mode=prod --skip-checks --firefox",
    "build:firefox:dev": "node scripts/build.mjs --skip-checks --firefox",
    "dev": "node scripts/build.mjs --watch --skip-checks",
    "dev:firefox": "node scripts/build.mjs --watch --skip-checks --firefox",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:browser": "node scripts/run-playwright.mjs test tests/visual/yaml-config.interaction.spec.ts",
    "test:e2e:browser:smoke": "node scripts/run-playwright.mjs test tests/visual/migration-harness.spec.ts --project=chromium-desktop",
    "test:e2e:browser:reader-panel": "node scripts/run-playwright.mjs test tests/e2e/readerPanelFlow.test.ts --config=playwright.reader.config.ts",
    "test:e2e:browser:firefox": "node scripts/run-firefox-browser-tests.mjs",
    "verify:preflight": "npm run typecheck:app && npm run typecheck:tests && npm run typecheck:strict && npm run lint -- --quiet && npm run build:dev && npm run audit:ui-architecture:report && npm run audit:interaction-contract:report && npm run audit:options-mainline:report && npm run audit:build:report && npm run audit:performance:report",
    "verify:preflight:full": "npm run verify:preflight && npm run test:e2e:browser && npm run test:e2e:browser:smoke",
    "test:ci": "npm run test:unit && npm run test:e2e && npm run test:e2e:browser && npm run test:e2e:browser:reader-panel && npm run test:e2e:browser:firefox",
    "visual:test": "node scripts/run-playwright.mjs test --config=playwright.config.ts",
    "visual:record": "node scripts/run-playwright.mjs test --config=playwright.config.ts --update-snapshots",
    "report:options-legacy": "node tools/options-css-legacy-report.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "package:ci": "node scripts/package.mjs",
    "package:firefox": "npm run build:firefox && node scripts/package-firefox.mjs",
    "package:firefox:sign": "npm run build:firefox && node scripts/package-firefox.mjs --sign",
    "package:trial": "node scripts/package-trial.mjs",
    "package:trial:quick": "node scripts/package-trial.mjs --skip-build",
    "release": "npm run build && node scripts/create-release.mjs",
    "prepare": "husky",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "audit:ui-architecture:report": "node tools/report-ui-architecture-alignment.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@zag-js/combobox": "^1.29.1",
    "@zag-js/core": "^1.29.1",
    "focus-trap": "^7.6.6",
    "intl-messageformat": "^10.7.18",
    "lucide": "^0.554.0",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.1.12",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/jsdom": "^21.1.5",
    "@types/node": "^22.5.4",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "archiver": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.10",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.6",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.0",
    "stylelint": "^16.25.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0",
    "web-ext": "^8.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/options/**/*.css": [
      "stylelint --fix",
      "npm run report:options-legacy"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
