{
  "name": "all-in-ob",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.tests.json",
    "build": "node scripts/build.mjs --mode=prod",
    "build:dev": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ci": "npm run test:unit && npm run test:e2e",
    "package": "npm run build && node scripts/package.mjs",
    "package:ci": "node scripts/package.mjs",
    "release": "npm run build && node scripts/create-release.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.12",
    "@types/jsdom": "^21.1.5",
    "@types/node": "^22.5.4",
    "@types/turndown": "^5.0.5",
    "archiver": "^6.0.2",
    "esbuild": "^0.23.0",
    "jsdom": "^27.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
